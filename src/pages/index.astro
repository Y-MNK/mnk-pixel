---
import Base from '../layouts/Base.astro';
---

<Base title="MNK Pixel — Web Development, SEO & AI Automation | NJ">
  <header class="site-header">
    <div class="wrap nav">
      <div class="logo">MNK<span>Pixel</span></div>
      <nav class="nav-links">
        <a href="#services">Services</a>
        <a href="#work">Work</a>
        <a href="#contact">Contact</a>
      </nav>
      <div class="nav-actions">
        <a class="btn" href="#contact">Free Growth Audit</a>
        <button id="theme-toggle" class="icon-btn" aria-label="Toggle theme">☀</button>
      </div>
    </div>
  </header>

  <main class="wrap main-wrap">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <section class="hero reveal">
      <div>
        <div class="tag">NJ / TRI-STATE / NATIONWIDE</div>
        <h1>Websites that <span class="accent">sell, rank, and automate</span> your business.</h1>
        <p class="sub">We rebuild outdated websites into premium digital systems that drive trust, traffic, and conversion.</p>
        <div class="cta">
          <a class="btn primary" href="#contact">Get Proposal</a>
          <a class="btn" href="#work">See Case Studies</a>
        </div>
        <div class="metrics">
          <div class="metric"><b>+143%</b><span>Organic traffic</span></div>
          <div class="metric"><b>+38%</b><span>Lead conversion</span></div>
          <div class="metric"><b>-62%</b><span>Load time</span></div>
          <div class="metric"><b>24h</b><span>Avg response</span></div>
        </div>
      </div>

      <div class="heroart floaty">
        <img src="/mock-assets/hero-collage.svg" alt="Case study collage placeholder" />
      </div>
    </section>

    <section id="services" class="reveal">
      <div class="cards">
        <article class="card"><div>🚀</div><h3>Launch</h3><p>Website build + conversion UX + SEO foundation.</p></article>
        <article class="card"><div>📈</div><h3>Rank</h3><p>Technical SEO + local visibility + content momentum.</p></article>
        <article class="card"><div>🤖</div><h3>Automate</h3><p>AI workflows for lead handling, follow-up, and reporting.</p></article>
      </div>
    </section>

    <section id="work" class="band reveal">
      <h2>Specialized for outdated medical office websites</h2>
      <p>Modernize patient trust, local visibility, and appointment flow with a conversion-first experience.</p>
      <img src="/mock-assets/before-after.svg" alt="Before and after modernization placeholder" />
    </section>

    <section id="contact" class="contact reveal">
      <h2>Start Your Project</h2>
      <p>Tell us what you need. We’ll reply within 24 hours.</p>
      <form class="form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
        <input type="text" name="name" placeholder="Name" required />
        <input type="email" name="email" placeholder="Email" required />
        <textarea name="message" rows="4" placeholder="Tell us about your project" required></textarea>
        <button type="submit" class="btn primary">Send Message</button>
      </form>
    </section>
  </main>

  <script>
    const root = document.documentElement;
    const btn = document.getElementById('theme-toggle');
    const saved = localStorage.getItem('mnk-theme') || 'dark';

    const applyTheme = (t) => {
      root.setAttribute('data-theme', t);
      localStorage.setItem('mnk-theme', t);
      if (btn) btn.textContent = t === 'light' ? '☾' : '☀';
    };

    applyTheme(saved);
    btn?.addEventListener('click', () => {
      const current = root.getAttribute('data-theme') || 'dark';
      applyTheme(current === 'dark' ? 'light' : 'dark');
    });
  </script>
</Base>

<style>
  :global(:root){
    --bg: #0c1016;
    --bg2: #0b1017;
    --text: #f3f7ff;
    --muted: #a4b1c8;
    --line: #2c3a50;
    --line2: #31455f;
    --acc: #2ea1ff;
    --acc2: #66d1ff;
    --cardA:#132437;
    --cardB:#112133;
  }

  :global(html[data-theme='light']){
    --bg: #eff4fb;
    --bg2: #ffffff;
    --text: #0f1a2b;
    --muted: #4d5f79;
    --line: #c6d5ea;
    --line2: #b8cbe4;
    --acc: #0b7cd8;
    --acc2: #2ea1ff;
    --cardA:#f8fbff;
    --cardB:#f1f7ff;
  }

  :global(body){
    margin:0;
    font-family:Inter,system-ui;
    background:radial-gradient(900px 450px at 85% -5%,color-mix(in srgb, var(--acc) 25%, transparent) 0,transparent 45%),linear-gradient(180deg,var(--bg),var(--bg2));
    color:var(--text);
    transition: background .3s ease, color .3s ease;
  }
  .wrap{max-width:1160px;margin:0 auto;padding:0 24px}
  .main-wrap{position:relative;overflow:hidden}

  .site-header{position:sticky;top:0;z-index:10;background:color-mix(in srgb,var(--bg) 75%, transparent);backdrop-filter:blur(9px);border-bottom:1px solid color-mix(in srgb,var(--line) 60%, transparent)}
  .nav{height:74px;display:flex;justify-content:space-between;align-items:center;gap:18px}
  .logo{font-size:25px;font-weight:900}.logo span{color:var(--acc2)}
  .nav-links{display:flex;gap:18px}
  .nav-links a{color:var(--muted);text-decoration:none;font-size:14px}
  .nav-links a:hover{color:var(--text)}
  .nav-actions{display:flex;gap:10px;align-items:center}

  .btn{padding:12px 18px;border-radius:12px;border:1px solid var(--line);color:var(--text);text-decoration:none;background:transparent;display:inline-block;transition:all .25s ease}
  .btn:hover{transform:translateY(-1px);border-color:var(--acc2)}
  .btn.primary{background:linear-gradient(135deg,var(--acc),var(--acc2));color:#041321;border:none;font-weight:800}
  .icon-btn{width:42px;height:42px;border-radius:12px;border:1px solid var(--line);background:transparent;color:var(--text);cursor:pointer}

  .hero{display:grid;grid-template-columns:1.08fr .92fr;gap:28px;padding:84px 0 36px}
  .tag{font-size:12px;letter-spacing:.11em;text-transform:uppercase;color:var(--muted)}
  h1{font-size:62px;line-height:1.03;letter-spacing:-.03em;margin:10px 0 14px}
  .accent{color:var(--acc2)}
  .sub{font-size:22px;line-height:1.55;color:var(--muted)}
  .cta{display:flex;gap:12px;margin-top:22px}
  .metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:18px}
  .metric{padding:13px;border:1px solid var(--line2);border-radius:11px;background:color-mix(in srgb,var(--cardB) 88%, transparent)}
  .metric b{font-size:30px}.metric span{display:block;color:var(--muted);font-size:13px}

  .heroart{border:1px solid var(--line2);border-radius:18px;background:linear-gradient(180deg,var(--cardA),var(--cardB));padding:12px}
  .heroart img{width:100%;border-radius:12px;display:block}

  .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;padding:30px 0}
  .card{padding:22px;border-radius:16px;border:1px solid var(--line2);background:linear-gradient(180deg,var(--cardA),var(--cardB));transition:transform .25s ease, box-shadow .25s ease}
  .card:hover{transform:translateY(-4px);box-shadow:0 12px 24px color-mix(in srgb,var(--acc) 15%, transparent)}
  .card h3{font-size:30px;margin:7px 0}.card p{margin:0;color:var(--muted);line-height:1.55}

  .band{margin:14px 0 44px;padding:24px;border:1px solid var(--line2);border-radius:20px;background:linear-gradient(180deg,var(--cardA),var(--cardB))}
  .band h2{font-size:50px;line-height:1.08;margin:0 0 8px}.band p{font-size:21px;color:var(--muted);margin:0 0 14px}
  .band img{width:100%;border-radius:14px;border:1px solid var(--line2)}

  .contact{padding:10px 0 70px}
  .contact h2{font-size:40px;margin:0 0 10px}
  .contact p{color:var(--muted);margin:0 0 16px}
  .form{display:grid;gap:10px;max-width:760px}
  .form input,.form textarea{background:color-mix(in srgb,var(--cardB) 90%, transparent);border:1px solid var(--line2);border-radius:10px;padding:12px;color:var(--text)}
  .form button{width:max-content}

  .orb{position:absolute;filter:blur(40px);opacity:.28;border-radius:999px;pointer-events:none;animation:drift 8s ease-in-out infinite}
  .orb-1{width:220px;height:220px;right:-40px;top:180px;background:var(--acc)}
  .orb-2{width:160px;height:160px;left:-40px;top:640px;background:var(--acc2);animation-delay:2s}

  .reveal{animation:fadeUp .7s ease both}
  .floaty{animation:floatY 5s ease-in-out infinite}

  @keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
  @keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
  @keyframes drift{0%,100%{transform:translate(0,0)}50%{transform:translate(12px,-10px)}}

  @media (max-width:980px){
    .nav-links{display:none}
    .hero{grid-template-columns:1fr}
    h1{font-size:45px}
    .metrics{grid-template-columns:1fr 1fr}
    .cards{grid-template-columns:1fr}
    .band h2{font-size:38px}
  }
</style>
