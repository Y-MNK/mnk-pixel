---
import Base from '../layouts/Base.astro';
---

<Base title="MNK Pixel — Web Development, SEO & AI Automation | NJ">
  <header class="site-header">
    <div class="wrap nav">
      <div class="logo">MNK<span>Pixel</span></div>
      <a class="btn" href="#contact">Free Growth Audit</a>
    </div>
  </header>

  <main class="wrap">
    <section class="hero">
      <div>
        <div class="tag">NJ / TRI-STATE / NATIONWIDE</div>
        <h1>Websites that <span class="accent">sell, rank, and automate</span> your business.</h1>
        <p class="sub">We rebuild outdated websites into premium digital systems that drive trust, traffic, and conversion.</p>
        <div class="cta">
          <a class="btn primary" href="#contact">Get Proposal</a>
          <a class="btn" href="#work">See Case Studies</a>
        </div>
        <div class="metrics">
          <div class="metric"><b>+143%</b><span>Organic traffic</span></div>
          <div class="metric"><b>+38%</b><span>Lead conversion</span></div>
          <div class="metric"><b>-62%</b><span>Load time</span></div>
          <div class="metric"><b>24h</b><span>Avg response</span></div>
        </div>
      </div>

      <div class="heroart">
        <img src="/mock-assets/hero-collage.svg" alt="Case study collage placeholder" />
      </div>
    </section>

    <section id="services">
      <div class="cards">
        <article class="card"><div>🚀</div><h3>Launch</h3><p>Website build + conversion UX + SEO foundation.</p></article>
        <article class="card"><div>📈</div><h3>Rank</h3><p>Technical SEO + local visibility + content momentum.</p></article>
        <article class="card"><div>🤖</div><h3>Automate</h3><p>AI workflows for lead handling, follow-up, and reporting.</p></article>
      </div>
    </section>

    <section id="work" class="band">
      <h2>Specialized for outdated medical office websites</h2>
      <p>Modernize patient trust, local visibility, and appointment flow with a conversion-first experience.</p>
      <img src="/mock-assets/before-after.svg" alt="Before and after modernization placeholder" />
    </section>

    <section id="contact" class="contact">
      <h2>Start Your Project</h2>
      <p>Tell us what you need. We’ll reply within 24 hours.</p>
      <form class="form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
        <input type="text" name="name" placeholder="Name" required />
        <input type="email" name="email" placeholder="Email" required />
        <textarea name="message" rows="4" placeholder="Tell us about your project" required></textarea>
        <button type="submit" class="btn primary">Send Message</button>
      </form>
    </section>
  </main>
</Base>

<style>
  :global(body){
    margin:0;
    font-family:Inter,system-ui;
    background:radial-gradient(900px 450px at 85% -5%,#123359 0,transparent 45%),linear-gradient(180deg,#0c1016,#0b1017);
    color:#f3f7ff;
  }
  .wrap{max-width:1160px;margin:0 auto;padding:0 24px}
  .site-header{position:sticky;top:0;z-index:10;background:rgba(10,14,20,.72);backdrop-filter:blur(9px);border-bottom:1px solid #233142}
  .nav{height:74px;display:flex;justify-content:space-between;align-items:center}
  .logo{font-size:25px;font-weight:900}.logo span{color:#66d1ff}
  .btn{padding:12px 18px;border-radius:12px;border:1px solid #2c3a50;color:#eaf2ff;text-decoration:none;background:transparent;display:inline-block}
  .btn.primary{background:linear-gradient(135deg,#2ea1ff,#66d1ff);color:#041321;border:none;font-weight:800}
  .hero{display:grid;grid-template-columns:1.08fr .92fr;gap:28px;padding:84px 0 36px}
  .tag{font-size:12px;letter-spacing:.11em;text-transform:uppercase;color:#b9c9e4}
  h1{font-size:62px;line-height:1.03;letter-spacing:-.03em;margin:10px 0 14px}
  .accent{color:#66d1ff}
  .sub{font-size:22px;line-height:1.55;color:#a4b1c8}
  .cta{display:flex;gap:12px;margin-top:22px}
  .metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:18px}
  .metric{padding:13px;border:1px solid #31455f;border-radius:11px;background:#101924}
  .metric b{font-size:30px}.metric span{display:block;color:#9cb5d7;font-size:13px}
  .heroart{border:1px solid #31507b;border-radius:18px;background:linear-gradient(180deg,#132338,#101c2d);padding:12px}
  .heroart img{width:100%;border-radius:12px;display:block}
  .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;padding:30px 0}
  .card{padding:22px;border-radius:16px;border:1px solid #2f4663;background:linear-gradient(180deg,#132437,#112133)}
  .card h3{font-size:30px;margin:7px 0}.card p{margin:0;color:#a7bddd;line-height:1.55}
  .band{margin:14px 0 44px;padding:24px;border:1px solid #3a5b86;border-radius:20px;background:linear-gradient(180deg,#132740,#102238)}
  .band h2{font-size:50px;line-height:1.08;margin:0 0 8px}.band p{font-size:21px;color:#b1c4e3;margin:0 0 14px}
  .band img{width:100%;border-radius:14px;border:1px solid #3c5e8c}
  .contact{padding:10px 0 70px}
  .contact h2{font-size:40px;margin:0 0 10px}
  .contact p{color:#a4b1c8;margin:0 0 16px}
  .form{display:grid;gap:10px;max-width:760px}
  .form input,.form textarea{background:#0f1823;border:1px solid #2e435f;border-radius:10px;padding:12px;color:#f3f7ff}
  .form button{width:max-content}
  @media (max-width:980px){.hero{grid-template-columns:1fr}h1{font-size:45px}.metrics{grid-template-columns:1fr 1fr}.cards{grid-template-columns:1fr}.band h2{font-size:38px}}
</style>
