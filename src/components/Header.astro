---
const navLinks = [
  { href: '/#services', label: 'Services' },
  { href: '/#work', label: 'Work' },
  { href: '/#about', label: 'About' },
  { href: '/#contact', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-dark-950/80 backdrop-blur-lg border-b border-dark-800/50">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-xl font-bold text-white tracking-tight">
        MNK<span class="text-brand-500">Pixel</span>
      </span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a href={link.href} class="text-sm text-dark-400 hover:text-white transition-colors duration-200">
          {link.label}
        </a>
      ))}
      <a href="/#contact" class="text-sm font-medium bg-brand-600 hover:bg-brand-500 text-white px-5 py-2 rounded-lg transition-colors duration-200">
        Get Started
      </a>
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-toggle" class="md:hidden text-dark-400 hover:text-white" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-dark-800/50 bg-dark-950/95 backdrop-blur-lg">
    <div class="px-6 py-4 flex flex-col gap-4">
      {navLinks.map(link => (
        <a href={link.href} class="text-dark-400 hover:text-white transition-colors duration-200">
          {link.label}
        </a>
      ))}
      <a href="/#contact" class="text-center font-medium bg-brand-600 hover:bg-brand-500 text-white px-5 py-2 rounded-lg transition-colors duration-200">
        Get Started
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu?.classList.add('hidden')));
</script>
